Options -Indexes +FollowSymLinks

# Enable the rewrite engine
RewriteEngine On

# Serve real files (CSS, JS, images, etc.) directly - never rewrite them
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else through index.php (the front controller)
RewriteRule ^ index.php [L]
