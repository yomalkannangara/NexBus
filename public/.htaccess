<IfModule mod_rewrite.c>
  RewriteEngine On

  # If your VM uses Apache and the document root points to this /public folder,
  # these rules route all "pretty" URLs (including /api/...) to index.php.
  # Existing files/directories are served directly.

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.php [L]
</IfModule>
